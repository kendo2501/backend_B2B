generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String            @unique @db.VarChar(50)
  description String?           @db.Text
  createdAt   DateTime          @default(now()) @map("created_at")
  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model Permission {
  id          String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code        String            @unique @db.VarChar(50)
  description String?           @db.Text
  createdAt   DateTime          @default(now()) @map("created_at")
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String      @map("role_id") @db.Uuid
  permissionId String      @map("permission_id") @db.Uuid
  role         Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id           String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  username     String        @unique @db.VarChar(50)
  passwordHash String        @map("password_hash") @db.VarChar(255)
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  deletedAt    DateTime?     @map("deleted_at")
  roles        UserRole[]
  attachments  Attachment[]  @relation("UploadedBy")
  refreshTokens RefreshToken[]

  @@map("users")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RefreshToken {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  tokenHash   String   @map("token_hash") @db.VarChar(255)
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Attachment {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  entityType   String   @map("entity_type") @db.VarChar(50)
  entityId     String   @map("entity_id") @db.Uuid
  fileName     String   @map("file_name") @db.VarChar(255)
  fileUrl      String   @map("file_url") @db.Text
  documentType String?  @map("document_type") @db.VarChar(50)
  uploadedById String?  @map("uploaded_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  uploadedBy   User?    @relation("UploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@map("attachments")
}

model Category {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name      String    @db.VarChar(100)
  parentId  String?   @map("parent_id") @db.Uuid
  parent    Category? @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryParent")
  products  Product[]

  @@map("categories")
}

model Product {
  id             String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  sku            String        @unique @db.VarChar(50)
  name           String        @db.VarChar(255)
  categoryId     String?       @map("category_id") @db.Uuid
  category       Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  baseUnit       String        @map("base_unit") @db.VarChar(20)
  displayUnit    String        @map("display_unit") @db.VarChar(20)
  attributes     Json?
  isActive       Boolean       @default(true) @map("is_active")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @default(now()) @map("updated_at")
  
  // ---> SỬA 2 DÒNG NÀY (Thêm @map) <---
  standardCost   Decimal       @default(0) @map("standard_cost") @db.Decimal(15,2) 
  listPrice      Decimal       @default(0) @map("list_price") @db.Decimal(15,2)    

  uomConversions UomConversion[]
  priceItems     PriceListItem[]
  orderItems     OrderItem[]
  shipmentItems  ShipmentItem[]
  inventoryRows  Inventory[]
  stockLedgers   StockLedger[]
  purchaseOrderItems PurchaseOrderItem[]

  @@map("products")
}

model UomConversion {
  id               String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  productId        String  @map("product_id") @db.Uuid
  fromUnit         String  @map("from_unit") @db.VarChar(20)
  toUnit           String  @map("to_unit") @db.VarChar(20)
  conversionFactor Decimal @map("conversion_factor") @db.Decimal(15,4)
  product          Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, fromUnit, toUnit])
  @@map("uom_conversions")
}

model PriceList {
  id          String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code        String          @unique @db.VarChar(50)
  name        String          @db.VarChar(100)
  tier        String?         @db.VarChar(20)
  validFrom   DateTime?       @map("valid_from")
  validTo     DateTime?       @map("valid_to")
  isActive    Boolean         @default(true) @map("is_active")
  items       PriceListItem[]

  @@map("price_lists")
}

model PriceListItem {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  priceListId    String    @map("price_list_id") @db.Uuid
  productId      String    @map("product_id") @db.Uuid
  unitPrice      Decimal   @map("unit_price") @db.Decimal(15,2)
  discountPercentage Decimal @default(0) @map("discount_percentage") @db.Decimal(5,2)
  priceList      PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product        Product   @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([priceListId, productId])
  @@map("price_list_items")
}

model BusinessPartner {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code         String    @unique @db.VarChar(50)
  name         String    @db.VarChar(255)
  type         String    @db.VarChar(20)
  tier         String?   @db.VarChar(20)
  creditLimit  Decimal   @default(0) @map("credit_limit") @db.Decimal(15,2)
  currentDebt  Decimal   @default(0) @map("current_debt") @db.Decimal(15,2)
  createdAt    DateTime  @default(now()) @map("created_at")
  deletedAt    DateTime? @map("deleted_at")
  orders       Order[]
  shipments    Shipment[]
  purchaseOrders PurchaseOrder[]
  debtLedger   DebtLedger[]
  payments     Payment[]

  @@map("business_partners")
}

model Warehouse {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code       String   @unique @db.VarChar(50)
  name       String   @db.VarChar(255)
  locationAddress String? @map("location_address") @db.Text
  locations  WarehouseLocation[]
  inventory  Inventory[]
  ledgers    StockLedger[]
  grns       GoodsReceiptNote[]

  @@map("warehouses")
}

model WarehouseLocation {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  warehouseId String   @map("warehouse_id") @db.Uuid
  binCode     String   @map("bin_code") @db.VarChar(50)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, binCode])
  @@map("warehouse_locations")
}

model Inventory {
  productId         String   @map("product_id") @db.Uuid
  warehouseId       String   @map("warehouse_id") @db.Uuid
  availableQuantity Decimal  @default(0) @map("available_quantity") @db.Decimal(15,2)
  reservedQuantity  Decimal  @default(0) @map("reserved_quantity") @db.Decimal(15,2)
  version           Int      @default(1)
  updatedAt         DateTime @default(now()) @map("updated_at")
  product           Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouse         Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@id([productId, warehouseId])
  @@map("inventory")
}

model StockLedger {
  id                String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  productId         String   @map("product_id") @db.Uuid
  warehouseId       String   @map("warehouse_id") @db.Uuid
  transactionType   String   @map("transaction_type") @db.VarChar(20)
  quantity          Decimal  @db.Decimal(15,2)
  movingAverageCost Decimal? @map("moving_average_cost") @db.Decimal(15,2)
  referenceId       String?  @map("reference_id") @db.Uuid
  createdById       String?  @map("created_by") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at")
  product           Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouse         Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@map("stock_ledger")
}

model PurchaseRequest {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  prNumber    String   @unique @map("pr_number") @db.VarChar(50)
  status      String   @db.VarChar(50)
  requestedBy String?  @map("requested_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("purchase_requests")
}

model PurchaseOrder {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  poNumber    String   @unique @map("po_number") @db.VarChar(50)
  prId        String?  @map("pr_id") @db.Uuid
  supplierId  String?  @map("supplier_id") @db.Uuid
  status      String   @db.VarChar(50)
  totalAmount Decimal  @default(0) @map("total_amount") @db.Decimal(15,2)
  createdBy  String?   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  items       PurchaseOrderItem[]
  supplier    BusinessPartner? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  goodsReceiptNotes GoodsReceiptNote[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  purchaseOrderId String @map("purchase_order_id") @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  quantity      Decimal  @db.Decimal(15,2)
  unitCost      Decimal  @map("unit_cost") @db.Decimal(15,2)
  receivedQuantity Decimal @default(0) @map("received_quantity") @db.Decimal(15,2)
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("purchase_order_items")
}

model GoodsReceiptNote {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  grnNumber   String   @unique @map("grn_number") @db.VarChar(50)
  poId        String?  @map("po_id") @db.Uuid
  warehouseId String?  @map("warehouse_id") @db.Uuid
  status      String   @db.VarChar(50)
  receivedDate DateTime @default(now()) @map("received_date")
  createdBy   String?  @map("created_by") @db.Uuid
  po          PurchaseOrder? @relation(fields: [poId], references: [id], onDelete: SetNull)
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  @@map("goods_receipt_notes")
}

model Order {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orderNumber    String   @unique @map("order_number") @db.VarChar(50)
  customerId     String?  @map("customer_id") @db.Uuid
  status         String   @db.VarChar(50)
  totalAmount    Decimal  @default(0) @map("total_amount") @db.Decimal(15,2)
  taxAmount      Decimal  @default(0) @map("tax_amount") @db.Decimal(15,2)
  discountAmount Decimal  @default(0) @map("discount_amount") @db.Decimal(15,2)
  finalAmount    Decimal  @default(0) @map("final_amount") @db.Decimal(15,2)
  createdBy      String?  @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  customer      BusinessPartner? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items         OrderItem[]
  shipments     Shipment[]
  debtLedger    DebtLedger[]

  @@map("orders")
}

model OrderItem {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orderId     String   @map("order_id") @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  quantity    Decimal  @db.Decimal(15,2)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(15,2)
  totalPrice  Decimal  @map("total_price") @db.Decimal(15,2)
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  shipmentItems ShipmentItem[]

  @@map("order_items")
}

model Shipment {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orderId        String?  @map("order_id") @db.Uuid
  shipmentNumber String   @unique @map("shipment_number") @db.VarChar(50)
  status         String   @db.VarChar(50)
  deliveryDate   DateTime? @map("delivery_date")
  createdAt      DateTime @default(now()) @map("created_at")
  deletedAt      DateTime? @map("deleted_at")
  order          Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  items          ShipmentItem[]

  partnerId String?
  partner   BusinessPartner? @relation(fields: [partnerId], references: [id])

  @@map("shipments")
}

model ShipmentItem {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  shipmentId       String   @map("shipment_id") @db.Uuid
  orderItemId      String   @map("order_item_id") @db.Uuid
  deliveredQuantity Decimal @map("delivered_quantity") @db.Decimal(15,2)
  shipment         Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  orderItem        OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Restrict)

  productId  String   @map("product_id") @db.Uuid
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("shipment_items")
}

model AccountingPeriod {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  periodName  String   @unique @map("period_name") @db.VarChar(20)
  startDate   DateTime @map("start_date") @db.Date
  endDate     DateTime @map("end_date") @db.Date
  isClosed    Boolean  @default(false) @map("is_closed")
  closedAt    DateTime? @map("closed_at")
  closedBy    String?  @map("closed_by") @db.Uuid

  @@map("accounting_periods")
}

model DebtLedger {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId     String?  @map("partner_id") @db.Uuid
  transactionType String @map("transaction_type") @db.VarChar(20)
  amount        Decimal  @db.Decimal(15,2)
  balanceAfter  Decimal  @map("balance_after") @db.Decimal(15,2)
  referenceId   String?  @map("reference_id") @db.Uuid
  periodId      String?  @map("period_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  partner       BusinessPartner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  order         Order?   @relation(fields: [referenceId], references: [id], onDelete: SetNull)

  @@map("debt_ledger")
}

model Payment {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  paymentNumber    String   @unique @map("payment_number") @db.VarChar(50)
  partnerId        String?  @map("partner_id") @db.Uuid
  amount           Decimal  @db.Decimal(15,2)
  paymentMethod    String?  @map("payment_method") @db.VarChar(50)
  unallocatedAmount Decimal @map("unallocated_amount") @db.Decimal(15,2)
  receivedDate     DateTime @default(now()) @map("received_date")
  createdBy        String?  @map("created_by") @db.Uuid
  partner          BusinessPartner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  allocations      PaymentAllocation[]

  @@map("payments")
}

model PaymentAllocation {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  paymentId      String   @map("payment_id") @db.Uuid
  invoiceId      String?  @map("invoice_id") @db.Uuid
  allocatedAmount Decimal @map("allocated_amount") @db.Decimal(15,2)
  createdAt      DateTime @default(now()) @map("created_at")
  payment        Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("payment_allocations")
}

model IdempotencyKey {
  key          String   @id @db.VarChar(255)
  requestPath  String   @map("request_path") @db.VarChar(255)
  responseBody Json?    @map("response_body")
  responseStatus Int?   @map("response_status")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("idempotency_keys")
}

model OutboxEvent {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  aggregateType String @map("aggregate_type") @db.VarChar(50)
  aggregateId  String   @map("aggregate_id") @db.Uuid
  eventType    String   @map("event_type") @db.VarChar(100)
  payload      Json
  status       String   @default("PENDING") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  processedAt  DateTime? @map("processed_at")

    @@map("outbox_events")
}

model DailyStat {
  statDate        DateTime @id @map("stat_date") @db.Date
  totalRevenue    Decimal  @default(0) @map("total_revenue") @db.Decimal(15,2)
  totalDebt       Decimal  @default(0) @map("total_debt") @db.Decimal(15,2)
  topSellingProducts Json? @map("top_selling_products")
  updatedAt       DateTime @default(now()) @map("updated_at")

  @@map("daily_stats")
}
